# REQUIRED — your OutSystems ODC tenant hostname (no scheme, no path)
OS_TENANT=mytenant.outsystems.dev

# OPTIONAL — pre-seed a bearer JWT to skip the OAuth flow at startup.
# Easiest path: just run the server and call the `authenticate` tool from your IDE
# (Claude Code, VS Code, etc.) — the OAuth/PKCE flow is built in and will store
# the token in memory. Set this env var only if you want headless startup.
#
# OS_BEARER_TOKEN=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...
